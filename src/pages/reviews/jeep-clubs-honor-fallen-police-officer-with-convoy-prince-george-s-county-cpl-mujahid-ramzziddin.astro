const youtubeId = "HaqaUIsIRTs";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2018-02-24";
export const specs = [
  {
    "label": "Category",
    "value": "Off-Road, Gear, Builds"
  },
  {
    "label": "Event",
    "value": "Convoy Honoring Cpl. Mujahid Ramzziddin"
