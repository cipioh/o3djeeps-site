export const description = "Join our exciting giveaway at O3D Jeeps to win fantastic off-road gear and accessories! Enter now to increase your chances of a great prize!";
const youtubeId = "PTq3NbcCoyo";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2016-03-13";
export const specs = [
