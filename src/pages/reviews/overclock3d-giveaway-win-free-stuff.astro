  {
    "label": "Sweepstakes Duration",
    "value": "Now through March 31st"
  }
];
const externalLinks = [{"label": "🔔 Please CLICK THE BELL if you want to see my videos! 🔔", "url": "https://o3djeeps.com"}, {"label": "🔔 Please CLICK THE BELL if you want to see my videos! 🔔", "url": "http://win.overclock3d-jku.com"}, {"label": "Some helpful O3D Jeeps links for you:", "url": "https://goo.gl/z2AFkB"}, {"label": "Some helpful O3D Jeeps links for you:", "url": "https://goo.gl/y6bCWo"}, {"label": "Some helpful O3D Jeeps links for you:", "url": "https://goo.gl/t8crvN"}];
---

<SiteLayout title={`${title} | o3djeeps`} description={description}>

<article>

<ReviewHero
  title={title}
  description={description}
  youtubeId={youtubeId}
  buyLink={buyLink}
  buyText={buyText}
  discountCode={discountCode}
  discountText={discountText}
  showPromo={Boolean(discountCode && buyLink)}
