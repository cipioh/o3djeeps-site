---
import SiteLayout from "../../layouts/SiteLayout.astro";
import ReviewHero from "../../components/ReviewHero.astro";

export const title = "I took a plane ride to do a brake job!";
export const description = "Learn how to tackle a brake job on a Jeep TJ, featuring step-by-step instructions and necessary tips from a recent father-son project.";
const youtubeId = "awTQLkRzc9U";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2022-07-15";
export const specs = [
  {
    "label": "Category",
    "value": "Maintenance, Mods, Off-Road"
  },
  {
    "label": "Brand",
    "value": "Jeep"
  },
  {
    "label": "Product",
    "value": "2004 Jeep TJ"
  },
  {
    "label": "Use Case",
    "value": "Brake replacement and maintenance"
  }
];
