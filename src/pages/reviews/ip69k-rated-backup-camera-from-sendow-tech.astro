export const title = "IP69K Rated Backup Camera from Sendow Tech";
export const description = "Explore the features and installation of the IP69K rated backup camera from Sendow Tech, a great solution for Jeep enthusiasts.";
const youtubeId = "IBuno6jeKlA";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2018-07-18";
export const specs = [
  {
    "label": "Category",
    "value": "Mods, Gear, Reviews"
  },
  {
    "label": "Brand",
    "value": "Sendow Tech"
  },
  {
    "label": "Product",
    "value": "Backup Camera"
  },
  {
    "label": "Use Case",
