export const description = "Discover Jeep Momma's modified 2015 Jeep Wrangler Unlimited Rubicon in our latest Readers' Rides episode. Get inspired!";
const youtubeId = "B9tgPImLePk";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2018-02-15";
export const specs = [
  {
    "label": "Category",
    "value": "Builds, Mods, Off-Road"
  },
  {
    "label": "Brand",
    "value": "Jeep"
  },
  {
