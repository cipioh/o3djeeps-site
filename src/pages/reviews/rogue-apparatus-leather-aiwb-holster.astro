export const title = "ROGUE APPARATUS LEATHER AIWB HOLSTER";
export const description = "An in-depth review of the Rogue Apparatus AIWB holster, designed for optimal performance and functionality.";
const youtubeId = "o0YtNzBPxL8";
const discountCode = null;
export const date = "2026-02-07";
const specs = [
  {
    "label": "Brand",
    "value": "Rogue Apparatus"
  },
  {
