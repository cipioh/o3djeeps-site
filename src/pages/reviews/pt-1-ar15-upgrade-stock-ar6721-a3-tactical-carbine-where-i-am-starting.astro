export const description = "Join us as we kick off an AR-15 upgrade series, examining the original setup and planned enhancements for optimal performance.";
const youtubeId = "00WHWxc8ToQ";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2019-02-08";
export const specs = [
  {
    "label": "Category",
    "value": "Firearms, Shooting & Training"
  },
  {
    "label": "Brand",
    "value": "Colt"
  },
  {
    "label": "Product",
