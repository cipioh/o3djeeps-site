export const title = "LIVE: Q&A with Tom Heusinger from HIDPROJECTORS.COM - Let's talk lighting!";
export const description = "Join us as we explore HID lighting with expert Tom Heusinger from HIDPROJECTORS.COM. Get insights, tips, and answers to your lighting questions.";
const youtubeId = "XUa7Ufo0rdM";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2018-04-06";
export const specs = [
  {
    "label": "Category",
    "value": "Gear, Mods, Maintenance"
  },
  {
    "label": "Brand",
    "value": "HIDPROJECTORS.COM"
  },
  {
    "label": "Product",
