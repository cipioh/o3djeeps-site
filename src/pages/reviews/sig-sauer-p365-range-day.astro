export const title = "Sig Sauer P365 Range Day";
export const description = "Exploring the reliability and performance of the Sig Sauer P365 after extensive shooting experience.";
const youtubeId = "xGvh6V6eXjA";
const discountCode = null;
export const date = "2020-01-04";
const specs = [
  {
    "label": "Brand",
    "value": "Sig Sauer"
  },
  {
    "label": "Product",
    "value": "P365"
  },
  {
    "label": "Category",
    "value": "Handgun"
  },
  {
    "label": "Use Case",
    "value": "Concealed Carry and Personal Defense"
  }
