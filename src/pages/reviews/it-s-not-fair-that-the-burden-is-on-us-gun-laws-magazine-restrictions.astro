import ReviewHero from "../../components/ReviewHero.astro";

export const title = "It's not Fair that the Burden is on US! Gun Laws - Magazine Restrictions";
export const description = "Exploring the burdens of restrictive gun laws on law-abiding citizens and the impact of magazine restrictions.";
const youtubeId = "ietskaprK0o";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2019-03-23";
export const specs = [
  {
    "label": "Category",
    "value": "Concealed Carry, Firearms"
  },
  {
    "label": "Subject",
    "value": "Gun Laws and Magazine Restrictions"
  },
  {
