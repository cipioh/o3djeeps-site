export const title = "Savior Obscura CCW Sling Bags Just Dropped — Quick 3L vs 5L Preview";
export const description = "Quick look at the Savior Obscura CCW sling bags comparing the 3L and 5L options.";
const youtubeId = "iMe7yk319ow";
const discountCode = null;

export const date = "2026-02-17";
const specs = [
  {
    "label": "Brand",
    "value": "Savior Equipment"
  },
  {
    "label": "Product",
    "value": "Obscura Sling Bag"
  },
  {
