const youtubeId = "-Giy4WLmlwg";
const buyLink = null;
const buyText = "View Product \u2192";
const discountCode = null;
const discountText = null;
export const date = "2020-07-13";
export const specs = [
  {
    "label": "Category",
    "value": "Reviews, Gear, Mods"
  },
  {
    "label": "Brand",
    "value": "TOPDON"
  },
  {
    "label": "Product",
    "value": "BT-100 Battery Tester"
  },
  {
    "label": "Use Case",
    "value": "Battery diagnostics and testing"
  }
];
const externalLinks = [{"label": "I'll leave it to you if you think this is worth $60.", "url": "https://amzn.to/308LRWr"}, {"label": "Here is the link to the NAPA tester if you liked it:", "url": "https://www.napaonline.com/en/p/NBTMDX225TV"}];
---

<SiteLayout title={`${title} | o3djeeps`} description={description}>

<article>

<ReviewHero
  title={title}
  description={description}
  youtubeId={youtubeId}
  buyLink={buyLink}
  buyText={buyText}
  discountCode={discountCode}
  discountText={discountText}
