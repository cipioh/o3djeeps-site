---
import SiteLayout from "../layouts/SiteLayout.astro";

/**
 * CHANNEL CONFIG (keep in sync with SiteLayout)
 * Later we can centralize this, but for now keep it simple
 */
const site = {
  name: "o3djeeps",
  description:
    "Real-world Jeep builds, off-road adventures, and gear reviews from the o3djeeps YouTube channel.",
};

const title = site.name;
const description = site.description;

const reviewModules = import.meta.glob("./reviews/*.astro", { eager: true });

const featuredArticles = Object.entries(reviewModules)
  .map(([path, module]) => {
    const slug = path.split("/").pop()?.replace(".astro", "") ?? "";

    const fallbackTitle = slug
      .split("-")
      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(" ");

    return {
      slug,
      title: module.default?.title ?? module.title ?? fallbackTitle,
      description:
        module.default?.description ??
        module.description ??
        descriptionsBySlug?.[slug] ??
        "",
      date: module.default?.date ?? module.date ?? "1970-01-01",
      href: `/reviews/${slug}`,
      image: `/images/thumbs/${slug}.jpg`,
    };
  })
  .sort((a, b) => new Date(b.date) - new Date(a.date));
---

<SiteLayout title={title} description={description}>
  <h2 class="section-title">Latest Content</h2>

  <div class="article-grid">
    {featuredArticles.map((article) => (
      <a href={article.href} class="article-card">
        <img
          src={article.image}
          alt={article.title}
          class="article-card-image"
        />
        <div class="article-card-body">
          <h3 class="article-card-title">{article.title}</h3>

          <p class="article-card-date">
            {new Date(article.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </p>

          <p class="article-card-excerpt">{article.description}</p>
        </div>
      </a>
    ))}
  </div>
</SiteLayout>