---
import SiteLayout from "../../layouts/SiteLayout.astro";

const site = {
  name: "o3djeeps",
};

export async function getStaticPaths() {
  const categories = [
    "builds",
    "off-road",
    "gear",
    "mods",
    "reviews",
    "maintenance"
  ];

  return categories.map((category) => ({
    params: { category }
  }));
}

const { category } = Astro.params;

const categoryTitles = {
  builds: "Builds",
  "off-road": "Off-Road",
  gear: "Gear",
  mods: "Mods",
  reviews: "Reviews",
  maintenance: "Maintenance"
};

const categoryTitle = categoryTitles[category] || category;

const modules = import.meta.glob("../reviews/*.astro", { eager: true });

function normalize(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/ & /g, " and ")
    .replace(/-/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

const categoryBuckets = {
  builds: [
    "builds",
    "build",
    "project build",
    "jeep build",
    "vehicle build",
    "overland build"
  ],

  "off-road": [
    "off road",
    "off-road",
    "trail",
    "trails",
    "wheeling",
    "recovery",
    "adventure"
  ],

  gear: [
    "gear",
    "equipment",
    "accessories",
    "tools",
    "storage",
    "recovery gear"
  ],

  mods: [
    "mods",
    "mod",
    "modification",
    "modifications",
    "upgrade",
    "upgrades",
    "install",
    "installation"
  ],

  reviews: [
    "reviews",
    "review",
    "product review",
    "gear review"
  ],

  maintenance: [
    "maintenance",
    "repair",
    "repairs",
    "service",
    "upkeep"
  ]
};

const posts = Object.entries(modules)
  .map(([path, mod]) => {
    const slug = path.split("/").pop()?.replace(".astro", "") ?? "";

    return {
      slug,
      url: `/reviews/${slug}`,
      title: mod.title || "",
      description: mod.description || "",
      date: mod.date || "",
      specs: mod.specs || []
    };
  })
  .filter((post) => {
    const categorySpec = post.specs.find((s) => s.label === "Category");
    const useCaseSpec = post.specs.find((s) => s.label === "Use Case");

    const bucket = categoryBuckets[category] || [];

    const categoryValues = (categorySpec?.value || "")
      .split(",")
      .map((v) => normalize(v))
      .filter(Boolean);

    const useCaseValues = [useCaseSpec?.value]
      .filter(Boolean)
      .map((v) => normalize(v));

    const values = [...categoryValues, ...useCaseValues];

    return values.some((v) =>
      bucket.some((item) => normalize(item) === v)
    );
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<SiteLayout title={`${categoryTitle} | ${site.name}`}>

  <h1>{categoryTitle}</h1>

  <p class="meta-note">
    Showing {posts.length} articles
  </p>

  <div class="article-grid">
    {posts.map((post) => (
      <a class="article-card" href={post.url}>
        <img
          src={`/images/thumbs/${post.slug}.jpg`}
          alt={post.title}
          class="article-card-image"
        />

        <div class="article-card-body">
          <h3 class="article-card-title">{post.title}</h3>

          <p class="article-card-excerpt">
            {post.description}
          </p>
        </div>
      </a>
    ))}
  </div>

</SiteLayout>