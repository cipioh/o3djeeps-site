---
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const categories = [
    "firearms",
    "shooting-training",
    "optics",
    "concealed-carry",
    "gear-accessories",
    "knives"
  ];

  return categories.map((category) => ({
    params: { category }
  }));
}

const { category } = Astro.params;

const categoryTitles = {
  firearms: "Firearms",
  "shooting-training": "Shooting & Training",
  optics: "Optics",
  "concealed-carry": "Concealed Carry",
  "gear-accessories": "Gear & Accessories",
  knives: "Knives"
};

const categoryTitle = categoryTitles[category] || category;

const modules = import.meta.glob("../reviews/*.astro", { eager: true });

function normalize(value) {
  return value
    .toLowerCase()
    .replace(/ & /g, " and ")
    .replace(/-/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

const categoryBuckets = {
  firearms: [
    "firearms",
    "firearm",
    "firearm accessories",
    "firearms accessories",
    "handgun",
    "pistol",
    "rifles",
    "ar 15 upgrades",
    "ar 15 accessories",
    "ar 15 upgrade"
  ],

  "shooting-training": [
    "shooting and training",
    "shooting training",
    "firearms training",
    "firearm training",
    "shooting practice",
    "firearms education",
    "training"
  ],

  optics: [
    "optics",
    "red dot sight",
    "optics maintenance"
  ],

  "concealed-carry": [
    "concealed carry",
    "concealed carry holsters",
    "concealment holster",
    "concealment bags",
    "holsters",
    "holster"
  ],

  "gear-accessories": [
    "gear and accessories",
    "gear accessories",
    "shooting gear",
    "training gear",
    "mag pouches",
    "hearing protection",
    "ear protection",
    "grip accessories",
    "shooting accessories",
    "edc gear",
    "gear"
  ],

  knives: [
    "knives",
    "fighting knives"
  ]
};

const posts = Object.entries(modules)
  .map(([path, mod]) => {
    const slug = path.split("/").pop().replace(".astro", "");

    return {
      slug,
      url: `/reviews/${slug}`,
      title: mod.title || "",
      description: mod.description || "",
      date: mod.date || "",
      specs: mod.specs || []
    };
  })
  .filter((post) => {
    const categorySpec = post.specs.find((s) => s.label === "Category");
    const useCaseSpec = post.specs.find((s) => s.label === "Use Case");

    const bucket = categoryBuckets[category] || [];

    const categoryValues = (categorySpec?.value || "")
      .split(",")
      .map((v) => normalize(v))
      .filter(Boolean);

    const useCaseValues = [useCaseSpec?.value]
      .filter(Boolean)
      .map(normalize);

    const values = [...categoryValues, ...useCaseValues];

    return values.some((v) =>
      bucket.some((item) => normalize(item) === v)
    );
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<SiteLayout title={`${categoryTitle} | blasterKRAFT`}>

<h1>{categoryTitle}</h1>

<p class="meta-note">
  Showing {posts.length} articles
</p>

<div class="article-grid">
  {posts.map((post) => (
    <a class="article-card" href={post.url}>
      <img
        src={`/images/thumbs/${post.slug}.jpg`}
        alt={post.title}
        class="article-card-image"
      />

      <div class="article-card-body">
        <h3 class="article-card-title">
          {post.title}
        </h3>

        <p class="article-card-excerpt">
          {post.description}
        </p>
      </div>
    </a>
  ))}
</div>

</SiteLayout>