---
import PromoBox from "./PromoBox.astro";
import SpecsTable from "./SpecsTable.astro";

const {
  title,
  description,
  youtubeId,
  buyLink,
  buyText,
  discountCode,
  specs,
  date,
  externalLinks
} = Astro.props;
---

<header class="review-hero">

<h1>{title}</h1>

<p class="review-date">
{new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric"
})}
</p>

<p class="review-intro">
{description}
</p>

{discountCode && (
  <PromoBox
    text="Discount Available"
    code={discountCode}
    href={buyLink}
    linkText={buyText || "View Product →"}
  />
)}

<div class="video-frame">
  <iframe
    src={`https://www.youtube.com/embed/${youtubeId}?enablejsapi=1`}
    title={title}
    allowfullscreen>
  </iframe>
</div>

{(specs || buyLink || externalLinks) && (
  <SpecsTable
    items={specs}
    buyLink={buyLink}
    externalLinks={externalLinks}
  />
)}

</header>