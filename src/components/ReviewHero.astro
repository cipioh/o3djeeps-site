---
import PromoBox from "./PromoBox.astro";
import SpecsTable from "./SpecsTable.astro";

const {
  title,
  description,
  youtubeId,
  buyLink,
  buyText,
  discountCode,
  specs,
  date,
  externalLinks,
  image: overrideImage
} = Astro.props;

const slug = Astro.url.pathname.split("/").filter(Boolean).pop();

/**
 * Image handling
 * - use override if provided
 * - otherwise default to slug-based thumbnail
 */
const image = overrideImage ?? `/images/thumbs/${slug}.jpg`;
---

<header class="review-hero">

  <!-- Hidden image for SEO / Pagefind -->
  <img
    src={image}
    alt={title}
    data-pagefind-meta="image[src], image_alt[alt]"
    style="display:none;"
    onerror="this.remove();"
  />

  <h1>{title}</h1>

  <p class="review-date">
    {new Date(date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric"
    })}
  </p>

  <p class="review-intro">
    {description}
  </p>

  {discountCode && (
    <PromoBox
      text="Discount Available"
      code={discountCode}
      href={buyLink}
      linkText={buyText || "View Product →"}
    />
  )}

  <div class="video-frame">
    <iframe
      src={`https://www.youtube.com/embed/${youtubeId}?enablejsapi=1`}
      title={title}
      allowfullscreen>
    </iframe>
  </div>

  {(specs || buyLink || externalLinks) && (
    <SpecsTable
      items={specs}
      buyLink={buyLink}
      externalLinks={externalLinks}
    />
  )}
</header>