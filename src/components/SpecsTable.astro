---
interface SpecItem {
  label: string;
  value: string;
}

interface LinkItem {
  label: string;
  url: string;
}

interface Props {
  title?: string;
  items?: SpecItem[];
  buyLink?: string | null;
  buyText?: string;
  discountText?: string | null;
  discountCode?: string | null;
  externalLinks?: LinkItem[];
}

const {
  title = "Quick Look",
  items = [],
  buyLink,
  buyText = "View Product →",
  discountText,
  discountCode,
  externalLinks = [],
} = Astro.props;

const normalizedBuyLink =
  !buyLink ||
  buyLink === "#" ||
  buyLink === "null" ||
  buyLink === "None" ||
  buyLink === "undefined"
    ? null
    : buyLink;

const hasBuyLink = !!normalizedBuyLink;
const hasUsefulLinks = Array.isArray(externalLinks) && externalLinks.length > 0;
---

<section class="specs-box">
  <h2>{title}</h2>

  <div class="specs-table">
    {items.map((item) => (
      <>
        <div class="specs-label">{item.label}</div>
        <div class="specs-value">{item.value}</div>
      </>
    ))}

    {hasBuyLink && (
      <>
        <div class="specs-label">Buy Link</div>
        <div class="specs-value">
          {discountText && (
            <div class="discount-callout">
              <span>{discountText}</span>
              {discountCode && (
                <>
                  {" "}
                  <strong>{discountCode}</strong>
                </>
              )}
            </div>
          )}

         <a href={normalizedBuyLink} target="_blank" rel="nofollow noopener noreferrer">
            {buyText}
          </a>
        </div>
      </>
    )}

    {hasUsefulLinks && (
      <>
        <div class="specs-label">Useful Links</div>
        <div class="specs-value">
          <ul class="external-links">
            {externalLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="nofollow noopener noreferrer"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </>
    )}
  </div>
</section>